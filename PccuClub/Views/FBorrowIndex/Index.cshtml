@model WebPccuClub.Models.FBorrowIndexViewModel

@{
	Layout = "_FrontBorrowLayout";
	ViewBag.Title = "資源借用系統";
}
<div class="col-xxl-8">
	<div class="contentWrapper">
		<h4 class="pageTitle">借用類別</h4>
		<hr>
		@if (null != Model.ResultModel)
        {
            <div class="thumblist">
                <div class="row">

                    @foreach (FBorrowIndexResultModel item in Model.ResultModel)
                    {
                        <div class="col-lg-3 col-md-6">
                            <div class="item">
                                <div class="imgbox">
                                    @if (item.CoverPath != null)
                                    {
                                        <div class="imgbox__inner-6-9">
                                            <div class="image" style="background-image: url(@item.CoverPath);"></div>
                                        </div>
                                    }
                                </div>
                                <div class="textbox">
                                    <div class="num">@item.Text</div>
                                    <div class="title d-flex justify-content-around mt-2">
                                        @using (Html.BeginForm("Detail", "FBorrowIndex", FormMethod.Post, new { style = "float:left" }))
                                        {
                                            <button type="submit" value="@item.ID" name="submitBtn" class="btn btn btn-secondary">相關說明</button>
                                        }

                                        @if (null != item.BorrowSDate && null != item.BorrowEDate)
                                        {
                                            DateTime now = DateTime.Now;

                                            if (now < item.BorrowSDate)
                                            {
                                                <div style="float:left">
                                                    <button type="button" class="btn btn-secondary" disabled>尚未開放</button>
                                                </div>
                                            }
                                            else if (now > item.BorrowEDate)
                                            {
                                                <div style="float:left">
                                                    <button type="button" class="btn btn-secondary" disabled>前往借用</button>
                                                </div>
                                            }
                                            else
                                            {
                                                @using (Html.BeginForm("Create", "FBorrowRecord", FormMethod.Post, new { style = "float:left" }))
                                                {
                                                    <button type="submit" value="@item.ID" name="submitBtn" class="btn btn-primary">前往借用</button>
                                                }
                                            }
                                        }
                                        
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                    }
                    
                </div>
            </div>
        }
	</div>
</div>

<script>

</script>