@model WebPccuClub.Models.HolisticPassportMangViewModel

@{
    Layout = "_BackendLayout";

    var perpage = Model.ConditionModel.PageSize;
}

<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <!-- /.row -->
        <div class="row">
            <div class="col-12">
                <form method="post" id="SearchForm" enctype="multipart/form-data" action="">
                    <div class="card">
                        <div class="card-header">
                            
                            <button type="button" class="btn btn-sm btn-outline-info" onclick="openColumnModal()">
                                <i class="fa fa-list"></i> 自選欄位
                            </button>
                            <div id="columnModalOverlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999;">
                                <div style="position:absolute; top:50%; left:50%; transform:translate(-50%, -50%); background:#fff; padding:20px; border-radius:8px; width:80%; max-width:1000px; box-shadow:0 5px 15px rgba(0,0,0,0.3);">
                                    <h4 style="margin-top:0; border-bottom:1px solid #eee; padding-bottom:10px;">請勾選匯出欄位</h4>

                                    <div style="margin: 15px 0;">
                                        @if (Model.ConditionModel.LstColumnDataModel.Count > 0)
                                        {
                                            <div style="margin-bottom: 10px; padding-bottom: 10px; border-bottom: 1px solid #eee;">
                                                <label style="font-weight: bold; cursor: pointer; color: #28a745;">
                                                    <input type="checkbox" id="selectAllCols" style="margin-right: 5px;">
                                                    全選 / 取消全選
                                                </label>
                                            </div>

                                            <div id="checkboxGrid" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px;">
                                                @foreach (ColumnDataModel item in Model.ConditionModel.LstColumnDataModel)
                                                {
                                                    <div style="padding: 5px 0; white-space: nowrap;">
                                                        <label style="font-weight: normal; cursor: pointer; display: flex; align-items: center;">
                                                            <input type="checkbox" class="col-cbx" value="@item.ColumnValue" @(item.IsDefault ? "checked" : "") style="margin-right: 5px;">
                                                            @item.ColumnName
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div style="text-align:right; border-top:1px solid #eee; padding-top:15px;">
                                        <button type="button" class="btn btn-secondary" onclick="closeColumnModal()">取消</button>
                                        <button type="button" class="btn btn-primary" onclick="saveColumnSettings()" style="background:#28a745; border-color:#28a745; color:#fff; padding:6px 12px; border-radius:4px;">確定</button>
                                    </div>
                                </div>
                            </div>

                            <button type="button" class="btn btn-sm btn-outline-dark" onclick="ExportSearchResult()">匯出填報紀錄</button>

                            <div class="card-tools">
                                <a href=@Url.Action("Create") class="btn btn-sm btn-success">新增</a>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                @Html.AntiForgeryToken()
                                
                                <div class="col-md-6 input-group mt-2">
                                    <input type="date" class="form-control" id="@Html.IdFor(m => m.ConditionModel.From_ReleaseDate)" name="@Html.NameFor(m => m.ConditionModel.From_ReleaseDate)">
                                    <span class="input-group-text">至</span>
                                    <input type="date" class="form-control" id="@Html.IdFor(m => m.ConditionModel.To_ReleaseDate)" name="@Html.NameFor(m => m.ConditionModel.To_ReleaseDate)">
                                </div>

                                <div class="col-md-3 col-sm-6 mt-2">
                                    @Html.DropDownListFor(m => m.ConditionModel.SchoolYear,(List<SelectListItem>)ViewBag.ddlAllSchoolYear,"全部學年度", new {@class = "form-control"})
                                </div>

                                <div class="col-md-3 col-sm-6 mt-2">
                                    @Html.DropDownListFor(m => m.ConditionModel.ActVerify,(List<SelectListItem>)ViewBag.ddlAllActVerify,"全部審核狀態", new {@class = "form-control"})
                                </div>

                                <div class="col-md-3 col-sm-6 mt-2">
                                    @Html.TextBoxFor(m => m.ConditionModel.ClubID, new {@class="form-control", placeholder="請輸入社團代號"})
                                </div>
                                <div class="col-md-3 col-sm-6 mt-2">
                                    @Html.TextBoxFor(m => m.ConditionModel.ClubCName, new {@class="form-control", placeholder="請輸入主辦單位名稱"})
                                </div>
                                <div class="col-md-3 col-sm-6 mt-2">
                                    @Html.TextBoxFor(m => m.ConditionModel.ActID, new {@class="form-control", placeholder="請輸入活動報備編號"})
                                </div>
                                <div class="col-md-3 col-sm-6 mt-2">
                                    @Html.TextBoxFor(m => m.ConditionModel.ActName, new {@class="form-control", placeholder="請輸入活動名稱"})
                                </div>

                                <div class="col-md-12 mt-2 row">
                                    <div class="col-md-6 col-sm-12 float-left">
                                        <span id="PageNow" class="text-sm text-muted" style="display:none;">
                                            目前為第 {{:pnow}} 頁 / 共 {{:ptotle}} 頁
                                        </span>
                                        <br />
                                        <span id="PageEver" class="text-muted text-sm" style="display:none;">
                                            每頁顯示 {{:pever}} 筆 / 共 {{:ptotleever}} 筆
                                        </span>
                                    </div>

                                    <div class="col-md-6 col-sm-12 float-right d-flex flex-wrap align-items-end justify-content-end p-0">
                                        @Html.Partial("_JumpPagePartial", @perpage)
                                        <input type="reset" class="btn btn-sm btn-outline-info mx-1 mt-2" value="清除條件">
                                        <input type="button" class="btn btn-sm btn-outline-danger mx-1 mt-2" value="搜尋" onclick="GoSearch(0)">
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                    @Html.HiddenFor(m => m.ConditionModel.Page)
                    @Html.HiddenFor(m => m.ConditionModel.PageSize)
                    @Html.HiddenFor(m => m.ConditionModel.TotalCount)
                    @Html.HiddenFor(m => m.ConditionModel.SelectedColumns)
                </form>
                <div id="SearchResultList" class="card"></div>

            </div>
            <!-- /.card -->
        </div>
    </div>
    <!-- /.row -->
</section>

<script>

    // 打開彈窗
function openColumnModal() {
    document.getElementById('columnModalOverlay').style.display = 'block';
}

// 關閉彈窗
function closeColumnModal() {
    document.getElementById('columnModalOverlay').style.display = 'none';
}

// 儲存並產生字串
function saveColumnSettings() {
    var selected = [];
    var checkboxes = document.querySelectorAll('.col-cbx');

    checkboxes.forEach(function (cb) {
        if (cb.checked) {
            selected.push(cb.value);
        }
    });

    // 更新隱藏欄位
    var finalString = selected.join(',');
    $('#@Html.IdFor(m => m.ConditionModel.SelectedColumns)').val(finalString);
        var SelectedColumns = $('#@Html.IdFor(m => m.ConditionModel.SelectedColumns)').val();
            console.log("已更新字串為: " + SelectedColumns);


    // 關閉彈窗
    closeColumnModal();
}

// 點擊遮罩背景也可關閉
window.onclick = function(event) {
    var overlay = document.getElementById('columnModalOverlay');
    if (event.target == overlay) {
        closeColumnModal();
    }
}

$(document).ready(function () {
    // 1. 全選/取消全選邏輯
    $('#selectAllCols').on('change', function () {
        var isChecked = $(this).prop('checked');
        $('.col-cbx').prop('checked', isChecked);
    });

    // 2. 自動連動全選按鈕狀態 (如果手動把所有子項勾選，全選也要自動打勾)
    $(document).on('change', '.col-cbx', function () {
        var allCount = $('.col-cbx').length;
        var checkedCount = $('.col-cbx:checked').length;
        
        // 如果全部都勾了，全選就打勾；否則取消全選
        $('#selectAllCols').prop('checked', allCount === checkedCount);
    });
});

    function GoSearch(source) {

        if (source == 0)
            $('#@(Html.IdFor(m => m.ConditionModel.Page))').val(0);

        var selected = [];
        $('.col-cbx:checked').each(function () {
            selected.push($(this).val());
        });

        $('#@Html.IdFor(m => m.ConditionModel.SelectedColumns)').val(selected.join(','));

        SendAjax({
            url: '@Url.Action("GetSearchResult")',
            data: $("#SearchForm").serialize(),
            success: function (result) {
                $('#SearchResultList').html(result);
            }
        });
    }

    function ExportSearchResult() {
        window.open('@Url.Action("ExportSearchResult")' + '?' + $("#SearchForm").serialize());
    }

    $('#JumpPergroup').change(function (e) {
        $("#@Html.IdFor(m => m.ConditionModel.PageSize)").val(e.target.value);
        GoSearch();
    });
    
    $('#Jumppage').change(function (e) {
        $("#@Html.IdFor(m => m.ConditionModel.Page)").val(e.target.value);
        GoSearch();
    });

    $('input:reset').click(function (e) {
        $("#@Html.IdFor(m => m.ConditionModel.PageSize)").val("10");
    });

    $('#@Html.IdFor(m => m.ConditionModel.From_ReleaseDate)').tooltip({ title: "建立時間[起]" });
    $('#@Html.IdFor(m => m.ConditionModel.To_ReleaseDate)').tooltip({ title: "建立時間[迄]" });
    $('#@Html.IdFor(m => m.ConditionModel.SchoolYear)').tooltip({ title: "學年度" });
    $('#@Html.IdFor(m => m.ConditionModel.ActVerify)').tooltip({ title: "審核狀態" });
    $('#@Html.IdFor(m => m.ConditionModel.ClubID)').tooltip({ title: "社團代號" });
    $('#@Html.IdFor(m => m.ConditionModel.ClubCName)').tooltip({ title: "主辦單位" });
    $('#@Html.IdFor(m => m.ConditionModel.ActID)').tooltip({ title: "活動報備編號" });
    $('#@Html.IdFor(m => m.ConditionModel.ActName)').tooltip({ title: "活動名稱" });
</script>