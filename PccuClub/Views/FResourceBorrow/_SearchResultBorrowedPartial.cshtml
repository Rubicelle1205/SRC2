@model WebPccuClub.Models.FResourceBorrowViewModel

@if (Model.ResourceResultModel.Count > 0)
{
    foreach (FResourceBorrowResourceResultModel item in Model.ResourceResultModel)
    {
        <div class="listItem">
            <div class="item item-sm">@item.MainClassText</div>
            <div class="item">@item.MainResourceName</div>
            <div class="item ">
                @item.RemainAmt
                @if (!string.IsNullOrEmpty(item.ShortDesc))
                {
                    <i class="fa-solid fa-circle-exclamation" onclick="ShowDesc('@item.ShortDesc')"></i>
                }
            </div>
            <div class="item">@item.AmtShelves</div>
            <div class="item">
                @using (Html.BeginForm("Edit", "FResourceBorrow", FormMethod.Post, new { style = "float:left" }))
                {
                    <button type="submit" value="@item.MainResourceID" name="submitBtn" class="mx-1 btn btn-sm btn-outline-primary">說明</button>
                }
            </div>
        </div>
    }
}

<!-- /.card-body -->

<style>
    /* 讓外層變成 Flex 容器，並讓子物件垂直居中 */
    .listItem {
        display: flex;
        align-items: center; /* 垂直置中 */
        justify-content: space-between; /* 根據你原本的排版調整，或用 flex-start */
    }

        /* 讓每個欄位內部也置中 */
        .listItem .item {
            display: flex;
            align-items: center; /* 垂直置中 */
            justify-content: center; /* 水平置中 */
            text-align: center; /* 確保多行文字時也能居中 */
            /* 彈性：如果需要欄位等寬，可以加上下面這行 */
            /* flex: 1; */
        }

            /* 修正表單產生的預設邊距，避免影響置中 */
            .listItem .item form {
                margin: 0;
                display: flex;
                align-items: center;
            }
</style>

<script>
    function ShowDesc(msg) {
        alert(msg);
    }
</script>